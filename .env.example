# Client-side (Vite)
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-side (Vercel serverless functions)
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GHL_API_KEY=your-ghl-api-key-here
GHL_LOCATION_ID=your-ghl-location-id-here
GHL_PIPELINE_ID=your-ghl-pipeline-id (optional — filters opportunity search)
WORKIZ_API_TOKEN=your-workiz-api-token-here
MANAGER_PHONE_NUMBER=+18005551234
CRON_SECRET=your-cron-secret (optional — open access if not set)
GHL_WEBHOOK_SECRET=your-webhook-secret (optional — open access if not set)
