{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/csr/submission-reminder", "schedule": "30 2 * * *" },
    { "path": "/api/workiz/revenue-sync", "schedule": "0 9 * * *" },
    { "path": "/api/csr/estimates-digest", "schedule": "30 17 * * *" },
    { "path": "/api/reports/weekly-executive", "schedule": "0 17 * * 0" },
    { "path": "/api/ghl/auto-assign", "schedule": "0 16,18,20,22,0,2,4 * * *" }
  ]
}
