{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/ghl/auto-assign.js": { "maxDuration": 120 },
    "api/ghl/unanswered-lead-check.js": { "maxDuration": 60 },
    "api/csr/morning-briefing.js": { "maxDuration": 120 },
    "api/ghl/lost-reason-check.js": { "maxDuration": 60 },
    "api/ghl/followup-sync.js": { "maxDuration": 120 },
    "api/csr/revenue-attribution.js": { "maxDuration": 120 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/csr/submission-reminder", "schedule": "30 2 * * *" },
    { "path": "/api/workiz/revenue-sync", "schedule": "0 9 * * *" },
    { "path": "/api/csr/estimates-digest", "schedule": "30 17 * * *" },
    { "path": "/api/reports/weekly-executive", "schedule": "0 17 * * 0" },
    { "path": "/api/ghl/auto-assign", "schedule": "0,30 0-1,3-4,18-23 * * *" },
    { "path": "/api/ghl/auto-assign", "schedule": "0,5,10,15,20,25,30 2 * * *" },
    { "path": "/api/ghl/unanswered-lead-check", "schedule": "*/5 0-4,18-23 * * *" },
    { "path": "/api/csr/morning-briefing", "schedule": "45 17 * * 1-5" },
    { "path": "/api/csr/shift-handoff", "schedule": "30 2 * * 1-5" },
    { "path": "/api/ghl/lost-reason-check", "schedule": "*/10 0-4,18-23 * * *" },
    { "path": "/api/ghl/followup-sync", "schedule": "0 18,20,22,0,2,4 * * *" },
    { "path": "/api/csr/revenue-attribution", "schedule": "0 9 * * *" }
  ]
}
